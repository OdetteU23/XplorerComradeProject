# XplorerComrade Frontend Environment Variables

# Backend API URLs - Development
# auth-server: handles user authentication (register, login, logout, current user)
VITE_AUTH_API=http://localhost:3000/api

# mediaContent-server: handles posts, comments, likes, travel plans, messages, notifications
VITE_MEDIA_API=http://localhost:3001/api

# upload-server: handles file uploads (images, videos)
VITE_UPLOAD_API=http://localhost:3002/api

# URL where uploaded files are served from
VITE_UPLOADS_URL=http://localhost:3002/uploads

# For production:
# VITE_AUTH_API=https://auth.xplorercomrade.com/api
# VITE_MEDIA_API=https://media.xplorercomrade.com/api
# VITE_UPLOAD_API=https://upload.xplorercomrade.com/api
# VITE_UPLOADS_URL=https://upload.xplorercomrade.com/uploads

